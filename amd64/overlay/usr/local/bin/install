#!/usr/bin/env python3
# -*- coding: utf-8 -*-
# Imports
import subprocess, platform, sys, os, math, locale, tkinter, time
from pathlib import Path
#


def t(msg):
    return msg # Temporary placeholder


# Variables
encoding = locale.getencoding()
lang, _ = locale.getlocale()
cpu_architecture = platform.machine()
portuguese = ["português", "portuguese", "portugiesisch"]
english = ["inglês", "english", "englisch"]
german = ["alemão", "german", "deutsch"]
filesystems = ["ext4", "btrfs", "gpfs"]
nproc = os.cpu_count()
indice_mensagem = 0
available_languages = [t("Portuguese"), t("English"), t("German")]
#


# Functions

def cleanwindow(window):
    for widget in window.winfo_children():
        widget.destroy()
def checkingrequirements():
    cleanwindow(window)
    if cpu_architecture != "x86_64":
        label = tkinter.Label(window, text=t("Your CPU architecture is not supported."))
        label.pack()
        button = tkinter.Button(window, text=t("Exit"), command=window.destroy)
        button.pack()
    
def choosinglanguage():
    cleanwindow(window)
    label = tkinter.Label(window, text=t("Choose your language:"))
    label.pack()
    # Dropdown menu for language selection
    language_names = list(available_languages)
    language_var = tkinter.StringVar(window)
    if language_names:
        language_var.set(language_names[0])
    dropdown = tkinter.OptionMenu(window, language_var, *language_names)
    dropdown.pack()
    global LANGUAGE
    LANGUAGE = language_var.get() # Language for Bit-OS
    # Button to confirm language selection
    button = tkinter.Button(window, text=t("Continue"), command=checkingrequirements)
    button.pack()
#


window = tkinter.Tk()
window.title("Bit-OS Install Wizard")
window.geometry("400x300")
if os.getuid() != 0:
    aviso = tkinter.Label(window, text=t("This program must be run as root!"))
    aviso.pack()
    botao = tkinter.Button(window, text=t("Exit"), command=window.destroy)
    botao.pack()
elif os.getuid() == 0:
    welcommingMessage = tkinter.Label(window, text=t("Welcome to Bit-OS Install Wizard!"))
    welcommingMessage.pack()
    botao = tkinter.Button(window, text=t("Continue"), command=choosinglanguage)
    botao.pack()
window.mainloop()