#!/usr/bin/env python3
# -*- coding: utf-8 -*-
import os, math, platform, subprocess, threading, portage, psutil, socket, tkinter as tk
from tkinter import messagebox, ttk

class GerenciadorParticoes:
    def __init__(self, root):
        self.root = root
        self.root.title("Instalação do Windows (Modo Gentoo)")
        self.root.geometry("650x450")
        self.root.configure(bg="#f0f0f0")

        # Título
        lbl_titulo = tk.Label(root, text="Onde deseja instalar o sistema?", font=("Arial", 14, "bold"), bg="#f0f0f0", fg="#003366")
        lbl_titulo.pack(pady=10)

        # Frame da Tabela
        frame_tabela = tk.Frame(root)
        frame_tabela.pack(pady=10, padx=20, fill=tk.BOTH, expand=True)

        # Treeview (Tabela) para listar discos e partições
        self.tree = ttk.Treeview(frame_tabela, columns=("Nome", "Tamanho", "Ponto de Montagem"), show="headings")
        self.tree.heading("Nome", text="Dispositivo/Partição")
        self.tree.heading("Tamanho", text="Tamanho")
        self.tree.heading("Ponto de Montagem", text="Montagem")
        
        self.tree.column("Nome", width=200)
        self.tree.column("Tamanho", width=100)
        self.tree.column("Ponto de Montagem", width=120)
        self.tree.pack(side=tk.LEFT, fill=tk.BOTH, expand=True)

        scrollbar = ttk.Scrollbar(frame_tabela, orient=tk.VERTICAL, command=self.tree.yview)
        self.tree.configure(yscroll=scrollbar.set)
        scrollbar.pack(side=tk.RIGHT, fill=tk.Y)

        # Frame de Botões (Estilo Instalador do Windows)
        frame_botoes = tk.Frame(root, bg="#f0f0f0")
        frame_botoes.pack(pady=15)

        btn_atualizar = tk.Button(frame_botoes, text="🔄 Atualizar", command=self.atualizar_discos, width=12)
        btn_atualizar.grid(row=0, column=0, padx=5)

        btn_novo = tk.Button(frame_botoes, text="➕ Novo", command=self.criar_particao, width=12)
        btn_novo.grid(row=0, column=1, padx=5)

        btn_excluir = tk.Button(frame_botoes, text="❌ Excluir", command=self.excluir_particao, width=12, fg="red")
        btn_excluir.grid(row=0, column=2, padx=5)

        # Entrada de tamanho para nova partição
        tk.Label(root, text="Tamanho para 'Novo' (ex: 50GiB, 2048MiB):", bg="#f0f0f0").pack()
        self.entry_tamanho = tk.Entry(root, width=20)
        self.entry_tamanho.pack(pady=5)
        self.entry_tamanho.insert(0, "10GiB")

        # Inicializa a tabela
        self.atualizar_discos()

    def obter_dados_lsblk(self):
        """Usa o lsblk para capturar os discos e partições reais do Gentoo"""
        try:
            resultado = subprocess.check_output(
                ["lsblk", "-b", "-o", "NAME,TYPE,SIZE,MOUNTPOINT", "-n", "-P"], 
                text=True
            )
            return resultado
        except Exception as e:
            messagebox.showerror("Erro", f"Não foi possível ler os discos: {e}")
            return ""

    def atualizar_discos(self):
        """Limpa a tabela e lê os dados do sistema novamente"""
        for item in self.tree.get_children():
            self.tree.delete(item)

        saida = self.obter_dados_lsblk()
        for linha in saida.strip().split('\n'):
            if not linha:
                continue
            
            dados = {}
            for parte in linha.split('" '):
                if '=' in parte:
                    chave, valor = parte.replace('"', '').split('=', 1)
                    dados[chave] = valor

            nome = dados.get("NAME", "")
            tipo = dados.get("TYPE", "")
            bytes_tamanho = int(dados.get("SIZE", 0))
            montagem = dados.get("MOUNTPOINT", "")

            tamanho_gb = f"{bytes_tamanho / (1024**3):.2f} GB"
            exibicao_nome = f"  └── /dev/{nome}" if tipo == "part" else f"/dev/{nome}"
            self.tree.insert("", tk.END, values=(exibicao_nome, tamanho_gb, montagem), tags=(nome,))

    def obter_selecao(self):
        """Retorna o nome do dispositivo selecionado na tabela"""
        item_selecionado = self.tree.selection()
        if not item_selecionado:
            messagebox.showwarning("Aviso", "Selecione um disco ou partição na lista.")
            return None
        tags = self.tree.item(item_selecionado, "tags")
        return tags[0] if tags else None

    def criar_particao(self):
        target = self.get_target_disk_or_part(is_delete=False)
        if not target:
            return

        tamanho = self.entry_tamanho.get().strip()
        
        if messagebox.askyesno("Confirmar", f"Deseja criar uma nova partição de {tamanho} em {target}?"):
            try:
                subprocess.run(["parted", "-s", target, "mkpart", "primary", "ext4", "1MiB", tamanho], check=True)
                messagebox.showinfo("Sucesso", "Partição criada com sucesso!")
                self.atualizar_discos()
            except Exception as e:
                messagebox.showerror("Erro", f"Falha ao criar partição: {e}")

    def excluir_particao(self):
        target = self.get_target_disk_or_part(is_delete=True)
        if not target:
            return

        if messagebox.askyesno("PERIGO", f"Tem certeza que deseja EXCLUIR a partição {target}?\nTodos os dados serão perdidos!"):
            import re
            match = re.match(r"(/dev/sd[a-z]|/dev/nvme\dn\d)p?(\d+)", target)
            if match:
                disco_pai = match.group(1)
                num_particao = match.group(2)
                try:
                    subprocess.run(["parted", "-s", disco_pai, "rm", num_particao], check=True)
                    messagebox.showinfo("Sucesso", "Partição excluída!")
                    self.atualizar_discos()
                except Exception as e:
                    messagebox.showerror("Erro", f"Falha ao excluir: {e}")
            else:
                messagebox.showerror("Erro", "Não foi possível determinar o número da partição.")

    def get_target_disk_or_part(self, is_delete=False):
        nome_curto = self.obter_selecao()
        if not nome_curto:
            return None

        caminho_completo = f"/dev/{nome_curto}"
        if is_delete and nome_curto in ["sda", "nvme0n1"]:
            messagebox.showerror("Bloqueado", "Você não pode excluir o disco inteiro por aqui, selecione uma partição específica.")
            return None
        return caminho_completo

class BitOSInstaller:
    def __init__(self, window):
        self.window = window
        self.window.title("Bit-OS Install Wizard")
        self.window.geometry("400x450")
        self.cpu_architecture, self.nproc = platform.machine(), os.cpu_count() or 1
        self.available_languages = ["Portuguese", "English", "German"]
        self.available_countries = ["Portugal", "Brasil", "Angola", "Moçambique", "Outro"]
        self.available_keymaps = ["pt", "br", "us", "es", "fr"]
        self.available_timezones = ["Europe/Lisbon", "America/Sao_Paulo", "Africa/Luanda", "Africa/Maputo", "UTC"]
        self.available_filesystems = ["btrfs"]
        self.available_profiles = ["minimal", "gaming", "study", "server", "normal"]
        self.available_envs = ["CLI", "CLI Avançada", "GNOME Puro", "GNOME Modificado", "KDE Puro", "KDE Modificado"]
        self.available_groups = ["wheel", "users", "audio", "video"]
        self.portagerequirements = ["net-misc/wget", "dev-vcs/git", "app-portage/cpuid2cpuflags", "net-firewall/nftables", "app-antivirus/clamav"]
        self.selected_language, self.selected_country, self.selected_hostname = None, None, None
        self.selected_keymap, self.selected_timezone, self.selected_filesystem = None, None, None
        self.want_swapfile, self.swapfile_size, self.selected_profile, self.selected_env, self.root_password = None, "0", None, None, None
        self.additional_users = []
        self.status_label, self.progressbar = None, None
        self.current_page = None
        self.history = []
        self.future = []
        self.check_root_and_start()
    def clean_window(self):
        for widget in self.window.winfo_children(): widget.destroy()
    def show_page(self, page_func):
        if self.current_page is not None:
            self.history.append(self.current_page)
            self.future.clear()
        self.current_page = page_func
        page_func()
    def go_back(self):
        if not self.history:
            return
        self.future.append(self.current_page)
        previous_page = self.history.pop()
        self.current_page = previous_page
        previous_page()
    def go_forward(self):
        if not self.future:
            return
        self.history.append(self.current_page)
        next_page = self.future.pop()
        self.current_page = next_page
        next_page()
    def add_navigation_buttons(self, continue_command=None, continue_label="Continue"):
        nav_frame = tk.Frame(self.window)
        nav_frame.pack(pady=15)
        if self.history:
            tk.Button(nav_frame, text="Back", width=10, command=self.go_back).pack(side="left", padx=5)
        if continue_command is not None:
            tk.Button(nav_frame, text=continue_label, width=10, command=continue_command).pack(side="left", padx=5)
        if self.future:
            tk.Button(nav_frame, text="Forward", width=10, command=self.go_forward).pack(side="left", padx=5)
    def is_package_installed(self, cp):
        return bool(portage.db[portage.root]["vartree"].dbapi.cp_list(cp))
    def get_total_ram_gb(self):
        return psutil.virtual_memory().total / (1024 ** 3)
    def get_free_storage_gb(self):
        try:
            return psutil.disk_usage('/').free / (1024 ** 3)
        except Exception: return 0.0
    def is_uefi_mode(self):
        return os.path.isdir("/sys/firmware/efi")
    def check_internet_connection(self):
        try:
            socket.gethostbyname("google.com")
            return True
        except socket.gaierror: return False
    # Partition selection is available as an installer step via test.py
    def check_root_and_start(self):
        if os.getuid() != 0:
            tk.Label(self.window, text="This program must be run as root!", fg="red").pack(pady=20)
            tk.Button(self.window, text="Exit", command=self.window.destroy).pack()
        elif not self.is_uefi_mode():
            tk.Label(self.window, text="UEFI Mode Required!", font=("Helvetica", 14, "bold"), fg="red").pack(pady=20)
            tk.Label(self.window, text="Bit-OS requires the system to be booted in UEFI mode.\nLegacy BIOS is not supported by this installer.", justify="center", wraplength=350).pack(pady=10)
            tk.Button(self.window, text="Exit", command=self.window.destroy).pack(pady=20)
        elif self.nproc < 2:
            tk.Label(self.window, text="Insufficient CPU Cores!", font=("Helvetica", 14, "bold"), fg="red").pack(pady=20)
            tk.Label(self.window, text="At least 2 logical CPU cores are required to install Bit-OS.", justify="center", wraplength=350).pack(pady=10)
            tk.Button(self.window, text="Exit", command=self.window.destroy).pack(pady=20)
        elif self.get_total_ram_gb() <= 2.0:
            tk.Label(self.window, text="Installation Impossible!", font=("Helvetica", 14, "bold"), fg="red").pack(pady=20)
            tk.Label(self.window, text="This device does not meet the minimum requirements.\nAt least more than 2 GB of RAM is required to install Bit-OS.", justify="center", wraplength=350).pack(pady=10)
            tk.Button(self.window, text="Exit", command=self.window.destroy).pack(pady=20)
        elif self.get_free_storage_gb() < 20.0:
            tk.Label(self.window, text="Insufficient Storage!", font=("Helvetica", 14, "bold"), fg="red").pack(pady=20)
            tk.Label(self.window, text="At least 20 GB of free disk space is required to install Bit-OS.", justify="center", wraplength=350).pack(pady=10)
            tk.Button(self.window, text="Exit", command=self.window.destroy).pack(pady=20)
        elif not self.check_internet_connection():
            tk.Label(self.window, text="No Internet Connection!", font=("Helvetica", 14, "bold"), fg="red").pack(pady=20)
            tk.Label(self.window, text="An active internet connection is required to fetch system packages and dependencies via Portage.", justify="center", wraplength=350).pack(pady=10)
            tk.Button(self.window, text="Exit", command=self.window.destroy).pack(pady=20)
        else:
            tk.Label(self.window, text="Welcome to Bit-OS Install Wizard!", font=("Helvetica", 12, "bold")).pack(pady=20)
            tk.Button(self.window, text="Continue", command=self.setup_progress_ui).pack()
    def setup_progress_ui(self):
        self.clean_window()
        self.status_label = tk.Label(self.window, text="Checking for required packages...", wraplength=350)
        self.status_label.pack(pady=20)
        self.progressbar = ttk.Progressbar(self.window, orient="horizontal", length=300, mode="determinate")
        self.progressbar.pack(pady=5)
        threading.Thread(target=self.check_and_install_logic, daemon=True).start()
    def update_ui_safely(self, text, progress_value, max_value=None):
        def update():
            if max_value is not None: self.progressbar.configure(maximum=max_value)
            self.status_label.config(text=text); self.progressbar.configure(value=progress_value)
        self.window.after(0, update)
    def check_and_install_logic(self):
        missing, total_reqs = [], len(self.portagerequirements)
        for idx, requirement in enumerate(self.portagerequirements, 1):
            self.update_ui_safely(f"Checking {requirement}... ({idx}/{total_reqs})", idx, total_reqs)
            if not self.is_package_installed(requirement): missing.append(requirement)
        if missing:
            self.window.after(0, lambda: self.show_error_and_exit(f"The following required packages are missing:\n\n" + "\n".join(missing) + "\n\nPlease install them manually using emerge before running the installer."))
            return
        self.update_ui_safely("Requirements met! Proceeding...", total_reqs)
        self.window.after(1500, lambda: self.show_page(self.choosing_language))
    def choosing_language(self):
        self.clean_window()
        tk.Label(self.window, text="Choose your language:").pack(pady=10)
        self.language_var = tk.StringVar(self.window, value=self.selected_language or self.available_languages[0])
        tk.OptionMenu(self.window, self.language_var, *self.available_languages).pack(pady=5)
        self.add_navigation_buttons(continue_command=lambda: self.show_page(self.choosing_country))
    def choosing_country(self):
        self.selected_language = self.language_var.get()
        self.clean_window()
        tk.Label(self.window, text="Select your country:").pack(pady=10)
        self.country_var = tk.StringVar(self.window, value=self.selected_country or self.available_countries[0])
        tk.OptionMenu(self.window, self.country_var, *self.available_countries).pack(pady=5)
        self.add_navigation_buttons(continue_command=lambda: self.show_page(self.choosing_hostname))
    def choosing_hostname(self):
        self.selected_country = self.country_var.get()
        self.clean_window()
        tk.Label(self.window, text="Enter Hostname (Computer Name):", font=("Helvetica", 11, "bold")).pack(pady=20)
        self.hostname_entry = tk.Entry(self.window, justify="center")
        self.hostname_entry.insert(0, self.selected_hostname or "bit-os")
        self.hostname_entry.pack(pady=10)
        self.add_navigation_buttons(continue_command=lambda: self.show_page(self.choosing_keymap))
    def choosing_keymap(self):
        self.selected_hostname = self.hostname_entry.get().strip().replace(" ", "-") or "bit-os"
        self.clean_window()
        tk.Label(self.window, text="Select Keyboard Layout (Keymap):").pack(pady=10)
        self.keymap_var = tk.StringVar(self.window, value=self.selected_keymap or self.available_keymaps[0])
        tk.OptionMenu(self.window, self.keymap_var, *self.available_keymaps).pack(pady=5)
        self.add_navigation_buttons(continue_command=lambda: self.show_page(self.choosing_timezone))
    def choosing_timezone(self):
        self.selected_keymap = self.keymap_var.get()
        self.clean_window()
        tk.Label(self.window, text="Select System Timezone:").pack(pady=10)
        self.timezone_var = tk.StringVar(self.window, value=self.selected_timezone or self.available_timezones[0])
        tk.OptionMenu(self.window, self.timezone_var, *self.available_timezones).pack(pady=5)
        self.add_navigation_buttons(continue_command=lambda: self.show_page(self.choosing_filesystem))
    # Partition selection screens removed. Flow proceeds directly to filesystem selection.
    def choosing_filesystem(self):
        self.clean_window()
        tk.Label(self.window, text="Select the filesystem for the installation:").pack(pady=10)
        self.filesystem_var = tk.StringVar(self.window, value=self.selected_filesystem or self.available_filesystems[0])
        tk.OptionMenu(self.window, self.filesystem_var, *self.available_filesystems).pack(pady=5)
        tk.Label(self.window, text="(btrfs is required for this installation)", font=("Helvetica", 9, "italic"), fg="gray").pack(pady=5)
        self.add_navigation_buttons(continue_command=self.goto_partition_selection)

    def goto_partition_selection(self):
        self.selected_filesystem = self.filesystem_var.get()
        self.show_page(self.partition_selection)

    def partition_selection(self):
        self.clean_window()
        tk.Label(self.window, text="Partition Selection", font=("Helvetica", 12, "bold")).pack(pady=20)
        tk.Label(
            self.window,
            text="Use the partition manager window to prepare disks and partitions.\nClick the button below to open it, then continue when finished.",
            wraplength=360,
            justify="center"
        ).pack(pady=10)
        tk.Button(self.window, text="Open Partition Manager", width=22, command=self.open_partition_manager).pack(pady=10)
        self.add_navigation_buttons(continue_command=lambda: self.show_page(self.validate_environment), continue_label="Continue")

    def open_partition_manager(self):
        if GerenciadorParticoes is None:
            self.show_error_and_exit("Partition manager is not available.")
            return
        if hasattr(self, "partition_window") and getattr(self, "partition_window").winfo_exists():
            self.partition_window.lift()
            return
        self.partition_window = tk.Toplevel(self.window)
        self.partition_window.title("Partition Manager")
        self.partition_window.geometry("700x450")
        self.partition_window.transient(self.window)
        self.partition_window.grab_set()
        self.partition_manager = GerenciadorParticoes(self.partition_window)

    def validate_environment(self):
        self.selected_filesystem = self.filesystem_var.get()
        if self.cpu_architecture != "x86_64":
            self.show_error_and_exit(f"This installer isn't made for {self.cpu_architecture} CPUs.")
            return
        self.show_page(self.asking_swapfile)
    def asking_swapfile(self):
        self.clean_window()
        tk.Label(self.window, text="Do you want to create a swapfile?", font=("Helvetica", 11, "bold")).pack(pady=20)
        tk.Label(self.window, text="A swapfile allows the system to use disk space as virtual memory.", wrap=350).pack(pady=10)
        self.swap_var = tk.BooleanVar(self.window, value=self.want_swapfile if self.want_swapfile is not None else True)
        tk.Checkbutton(self.window, text="Enable Swapfile", variable=self.swap_var).pack(pady=10)
        self.add_navigation_buttons(continue_command=self.process_swapfile_decision)
    def process_swapfile_decision(self):
        self.want_swapfile = self.swap_var.get()
        self.show_page(self.choosing_swap_size if self.want_swapfile else self.choosing_profile)
    def choosing_swap_size(self):
        self.clean_window()
        tk.Label(self.window, text="Enter Swapfile Size:", font=("Helvetica", 11, "bold")).pack(pady=20)
        tk.Label(self.window, text="Specify the size in Gigabytes (GB):", wrap=350).pack(pady=5)
        self.size_entry = tk.Entry(self.window, justify="center")
        self.size_entry.insert(0, self.swapfile_size or "4")
        self.size_entry.pack(pady=10)
        self.add_navigation_buttons(continue_command=self.save_swap_size)
    def save_swap_size(self):
        self.swapfile_size = self.size_entry.get().strip() or "4"
        self.show_page(self.choosing_profile)
    def choosing_profile(self):
        self.clean_window()
        tk.Label(self.window, text="Select PC Configuration Profile:", font=("Helvetica", 11, "bold")).pack(pady=20)
        self.profile_var = tk.StringVar(self.window, value=self.selected_profile or self.available_profiles[4])
        tk.OptionMenu(self.window, self.profile_var, *self.available_profiles).pack(pady=10)
        self.add_navigation_buttons(continue_command=self.save_profile)
    def save_profile(self):
        self.selected_profile = self.profile_var.get()
        self.show_page(self.choosing_env)
    def choosing_env(self):
        self.clean_window()
        tk.Label(self.window, text="Select Desktop Environment:", font=("Helvetica", 11, "bold")).pack(pady=20)
        self.env_var = tk.StringVar(self.window, value=self.selected_env or self.available_envs[0])
        tk.OptionMenu(self.window, self.env_var, *self.available_envs).pack(pady=10)
        self.add_navigation_buttons(continue_command=self.save_env)
    def save_env(self):
        self.selected_env = self.env_var.get()
        self.show_page(self.asking_root_password)
    def asking_root_password(self):
        self.clean_window()
        tk.Label(self.window, text="Set Root Password:", font=("Helvetica", 11, "bold")).pack(pady=20)
        tk.Label(self.window, text="Enter the desired password for the root user:", wrap=350).pack(pady=5)
        self.pass_entry = tk.Entry(self.window, show="*", justify="center")
        self.pass_entry.pack(pady=10)
        self.add_navigation_buttons(continue_command=self.save_root_password)
    def save_root_password(self):
        self.root_password = self.pass_entry.get()
        self.show_page(self.asking_user_creation)
    def asking_user_creation(self):
        self.clean_window()
        title = "Create a Standard User?" if not self.additional_users else "Create Another User?"
        tk.Label(self.window, text=title, font=("Helvetica", 11, "bold")).pack(pady=15)
        tk.Label(self.window, text="Would you like to add a standard user account to the system?", wrap=350).pack(pady=5)
        self.user_checkbox_var = tk.BooleanVar(self.window, value=True)
        tk.Checkbutton(self.window, text="Add User Account", variable=self.user_checkbox_var).pack(pady=10)
        self.add_navigation_buttons(continue_command=self.process_user_decision)
    def process_user_decision(self):
        self.setup_user_details() if self.user_checkbox_var.get() else self.proceed_to_next_installer_stage()
    def setup_user_details(self):
        self.clean_window()
        tk.Label(self.window, text=f"User Setup (Account #{len(self.additional_users)+1}):", font=("Helvetica", 11, "bold")).pack(pady=5)
        tk.Label(self.window, text="Username:").pack(); self.username_entry = tk.Entry(self.window, justify="center"); self.username_entry.pack(pady=2)
        tk.Label(self.window, text="Password:").pack(); self.user_pass_entry = tk.Entry(self.window, show="*", justify="center"); self.user_pass_entry.pack(pady=2)
        tk.Label(self.window, text="Select Group:").pack()
        self.group_var = tk.StringVar(self.window, value=self.available_groups[0])
        tk.OptionMenu(self.window, self.group_var, *self.available_groups).pack(pady=2)
        self.c_users_var = tk.BooleanVar(self.window, value=False)
        tk.Checkbutton(self.window, text="Create folder in C:\\Users\\", variable=self.c_users_var).pack(pady=5)
        tk.Button(self.window, text="Save User", command=self.save_user_details).pack(pady=10)
        self.add_navigation_buttons()
    def save_user_details(self):
        uname = self.username_entry.get().strip()
        if uname: self.additional_users.append({"name": uname, "pass": self.user_pass_entry.get(), "group": self.group_var.get(), "c_users": self.c_users_var.get()})
        self.asking_user_creation()
    def proceed_to_next_installer_stage(self):
        self.clean_window()
        swap_info = f"Yes ({self.swapfile_size} GB)" if self.want_swapfile else "No"
        user_list = ", ".join([f"{u['name']}" for u in self.additional_users]) or "None"
        part_info = f"Filesystem: {self.selected_filesystem or 'btrfs'}"
        summary = f"Lang: {self.selected_language} | Country: {self.selected_country}\nHostname: {self.selected_hostname} | Keymap: {self.selected_keymap}\nTimezone: {self.selected_timezone}\n{part_info}\nSwap: {swap_info} | Profile: {self.selected_profile}\nEnv: {self.selected_env} | Root Pass: [SET]\nUsers ({len(self.additional_users)}): {user_list}\n\nReady to install Bit-OS!"
        tk.Label(self.window, text=summary, fg="green", font=("Helvetica", 10), justify="center").pack(pady=20)
        tk.Button(self.window, text="Begin Installation", command=self.window.destroy).pack()
    def show_error_and_exit(self, msg):
        self.clean_window(); tk.Label(self.window, text="An Error Occurred", font=("Helvetica", 12, "bold"), fg="red").pack(pady=10)
        tk.Label(self.window, text=msg, fg="black", justify="center", wraplength=350).pack(pady=10)
        tk.Button(self.window, text="Exit Installer", command=self.window.destroy).pack(pady=10)
if __name__ == "__main__":
    root = tk.Tk(); app = BitOSInstaller(root); root.mainloop()