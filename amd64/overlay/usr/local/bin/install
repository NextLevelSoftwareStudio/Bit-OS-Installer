#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import os
import math
import locale
import platform
import subprocess
import threading
import tkinter as tk
from tkinter import ttk
import portage
cpu_architecture = platform.machine()
nproc = os.cpu_count() or 1
available_languages = ["Portuguese", "English", "German"]
portagerequirements = ["net-misc/wget", "dev-vcs/git"]
portage_cores = math.ceil((nproc / 100) * 75)
def cleanwindow(window_obj):
    for widget in window_obj.winfo_children():
        widget.destroy()
def is_package_installed(cpv):
    vartree = portage.db[portage.root]["vartree"]
    return bool(vartree.dbapi.match(cpv))
def run_requirements_check():
    global LANGUAGE
    LANGUAGE = language_var.get()
    if cpu_architecture != "x86_64":
        window.after(0, lambda: show_error_and_exit(f"This installer isn't made for {cpu_architecture} CPUs."))
        return
    window.after(0, setup_progress_ui)
def setup_progress_ui():
    cleanwindow(window)
    global status_label, progressbar
    status_label = tk.Label(window, text="Checking for required packages...")
    status_label.pack(pady=10)
    progressbar = ttk.Progressbar(window, orient="horizontal", length=300, mode="determinate", maximum=len(portagerequirements))
    progressbar.pack(pady=5)
    threading.Thread(target=check_and_install_logic, daemon=True).start()
def check_and_install_logic():
    missing = []
    for idx, requirement in enumerate(portagerequirements, 1):
        window.after(0, lambda i=idx, req=requirement: update_progress(f"Checking {req}... ({i}/{len(portagerequirements)})", i))
        if not is_package_installed(requirement):
            missing.append(requirement)
    if missing:
        window.after(0, lambda: progressbar.configure(maximum=len(missing), value=0))
        for idx, package in enumerate(missing, 1):
            window.after(0, lambda i=idx, pkg=package: update_progress(f"Installing {pkg}... ({i}/{len(missing)})", i-1)) 
            try:
                subprocess.run(["emerge", "--verbose", package], check=True)
            except subprocess.CalledProcessError:
                print(f"Failed to install {package}")
            window.after(0, lambda i=idx: progressbar.configure(value=i))
    window.after(0, lambda: update_progress("Requirements met! Proceeding...", len(portagerequirements)))
def update_progress(text, value):
    status_label.config(text=text)
    progressbar.configure(value=value)
def show_error_and_exit(msg):
    cleanwindow(window)
    label = tk.Label(window, text=msg)
    label.pack(pady=20)
    button = tk.Button(window, text="Exit", command=window.destroy)
    button.pack()
def choosinglanguage():
    cleanwindow(window)
    label = tk.Label(window, text="Choose your language:")
    label.pack(pady=10)
    global language_var
    language_var = tk.StringVar(window)
    language_var.set(available_languages[0])
    dropdown = tk.OptionMenu(window, language_var, *available_languages)
    dropdown.pack(pady=5)
    button = tk.Button(window, text="Continue", command=run_requirements_check)
    button.pack(pady=10)
window = tk.Tk()
window.title("Bit-OS Install Wizard")
window.geometry("400x300")
if os.getuid() != 0:
    aviso = tk.Label(window, text="This program must be run as root!")
    aviso.pack(pady=20)
    botao = tk.Button(window, text="Exit", command=window.destroy)
    botao.pack()
else:
    welcommingMessage = tk.Label(window, text="Welcome to Bit-OS Install Wizard!")
    welcommingMessage.pack(pady=20)
    botao = tk.Button(window, text="Continue", command=choosinglanguage)
    botao.pack()
window.mainloop()